{
  "manifest_version": 3,
  "name": "Minimal LinkedIn",
  "version": "2.2",
  "description": "Hides the LinkedIn feed and adds a persistent launcher bar that deep-links to Messages and the LinkedIn games.",

  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "action": {
    "default_title": "Minimal LinkedIn",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },

  "host_permissions": [
    "*://*.linkedin.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ]
}
